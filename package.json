{
  "name": "appointly",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.7.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "docker-compose up -d && turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @appointly/db prisma generate",
    "db:push": "pnpm --filter @appointly/db prisma db push",
    "db:migrate": "pnpm --filter @appointly/db prisma migrate dev",
    "db:seed": "pnpm --filter @appointly/db prisma db seed",
    "db:studio": "pnpm --filter @appointly/db prisma studio"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.5.4"
  }
}
