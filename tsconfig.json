{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@appointly/db": ["./packages/db/src/index.ts"],
      "@appointly/shared": ["./packages/shared/src/index.ts"],
      "@appointly/api": ["./packages/api/src/index.ts"],
      "@appointly/ui": ["./packages/ui/src/index.ts"]
    }
  },
  "exclude": ["node_modules"]
}
