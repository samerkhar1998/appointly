# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://appointly:password@localhost:5432/appointly"

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── WhatsApp / Twilio ────────────────────────────────────────────────────────
# Required for real OTP delivery and appointment confirmations.
# Without these, messages are logged to console in development.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
TWILIO_SMS_FROM=""

# ─── Email / Resend ───────────────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@appointly.co"

# ─── Redis / BullMQ (for reminder jobs) ──────────────────────────────────────
REDIS_URL="redis://localhost:6379"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Cloudinary (for logo / cover uploads) ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Testing ──────────────────────────────────────────────────────────────────
# When set, every OTP sent will use this fixed code instead of a random 6-digit number.
# Useful for automated tests and local development — never set this in production.
# TEST_OTP_CODE="000000"
